# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/diaolema.db

# 和风天气（https://dev.qweather.com/）
QWEATHER_API_KEY=your_hefeng_api_key

# 微信小程序（生成小程序码用）
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_secret
WECHAT_MASTER_KEY=your_master_key

# 服务
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
