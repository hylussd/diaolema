.weather-card {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(26, 26, 46, 0.88);
  backdrop-filter: blur(12px);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 32rpx;
  color: #fff;
}

.weather-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.temp-wrap {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.temp {
  font-size: 64rpx;
  font-weight: 300;
  line-height: 1;
}

.condition {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

.weather-details {
  display: flex;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.detail-item .label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
}

.detail-item .value {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

.weather-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid rgba(255,255,255,0.1);
}

.tip {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.5);
}

.loading-card,
.empty-card {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}
