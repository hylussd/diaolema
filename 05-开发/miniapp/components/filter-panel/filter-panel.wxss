.filter-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 100;
  pointer-events: none;
  transition: background 0.25s;
}

.filter-overlay.show {
  background: rgba(0, 0, 0, 0.45);
  pointer-events: all;
}

.filter-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.filter-overlay.show .filter-panel {
  transform: translateY(0);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1px solid #f3f4f6;
  flex-shrink: 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.close-btn {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
}

.filter-section {
  padding: 24rpx 0;
  border-bottom: 1px solid #f3f4f6;
}

.filter-section:last-child {
  border-bottom: none;
}

.section-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.range-value {
  font-size: 24rpx;
  color: #6b7280;
}

.fish-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fish-chip {
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 24rpx;
  transition: all 0.15s;
}

.fish-chip.active {
  background: #dbeafe;
  color: #1d4ed8;
  font-weight: 500;
}

.terrain-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #374151;
}

.arrow {
  font-size: 28rpx;
  color: #9ca3af;
}

.panel-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  border-top: 1px solid #f3f4f6;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-ghost {
  background: #f3f4f6;
  color: #4b5563;
}

.btn-primary {
  background: #3b82f6;
  color: #fff;
}
