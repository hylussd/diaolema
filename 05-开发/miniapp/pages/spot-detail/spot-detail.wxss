.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.mini-map {
  width: 100%;
  height: 360rpx;
}

.map-tip {
  text-align: center;
  font-size: 24rpx;
  color: #3b82f6;
  padding: 8rpx;
  background: #eff6ff;
}

.section {
  background: #fff;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1f2937;
}

.spot-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.spot-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1px solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 26rpx;
  color: #6b7280;
  flex-shrink: 0;
  width: 80rpx;
}

.value {
  font-size: 26rpx;
  color: #1f2937;
  flex: 1;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag-fish {
  background: #f0fdf4;
  color: #16a34a;
}

/* 天气摘要 */
.weather-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.w-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.w-temp {
  font-size: 52rpx;
  font-weight: 300;
  color: #1f2937;
}

.w-condition {
  font-size: 26rpx;
  color: #6b7280;
}

.w-details {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  font-size: 24rpx;
  color: #6b7280;
  text-align: right;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 20rpx;
}

.actions .btn {
  flex: 1;
}
