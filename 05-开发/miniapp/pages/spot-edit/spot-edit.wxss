.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.form-section {
  background: #fff;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.location-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.loc-btn {
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.terrain-picker {
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
}

.picker-value {
  font-size: 28rpx;
  color: #1f2937;
}

.fish-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.fish-chip {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 26rpx;
  color: #6b7280;
  background: #fff;
}

.fish-chip.active {
  border-color: #22c55e;
  color: #16a34a;
  background: #f0fdf4;
}

.submit-bar {
  padding: 24rpx 20rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  box-shadow: 0 -1px 6px rgba(0,0,0,0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
}
