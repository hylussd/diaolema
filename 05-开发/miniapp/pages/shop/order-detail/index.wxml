<!-- pages/shop/order-detail/index.wxml -->
<view class="page">
  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{order}}">
    <!-- 订单状态区 -->
    <view class="status-section">
      <view class="status-tag-lg {{getStatusClass(order.status)}}">{{getStatusLabel(order.status)}}</view>
      <text class="status-desc">{{getStatusText(order.status)}}</text>
    </view>

    <!-- 收货地址 -->
    <view class="section">
      <view class="section-title">收货信息</view>
      <view class="address-row">
        <text class="addr-name">{{order.address_name}}</text>
        <text class="addr-phone">{{order.address_phone}}</text>
      </view>
      <text class="addr-detail">{{order.address_detail}}</text>
    </view>

    <!-- 商品列表 -->
    <view class="section" wx:if="{{order.items && order.items.length > 0}}">
      <view class="section-title">商品明细</view>
      <view class="order-items">
        <view class="order-item" wx:for="{{order.items}}" wx:key="id">
          <image class="item-img" src="{{item.images && item.images[0] || '/assets/icons/me.png'}}" mode="aspectFill" />
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-specs">{{item.specs ? JSON.stringify(item.specs) : ''}}</text>
            <view class="item-bottom">
              <text class="item-price">¥{{formatPrice(item.price)}}</text>
              <text class="item-qty">x{{item.quantity}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="section">
      <view class="section-title">订单信息</view>
      <view class="info-row">
        <text class="info-label">订单号</text>
        <text class="info-value">{{order.order_no}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{formatTime(order.created_at)}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">支付状态</text>
        <text class="info-value">{{getPayStatusLabel(order.pay_status)}}</text>
      </view>
      <view class="info-row" wx:if="{{order.remark}}">
        <text class="info-label">备注</text>
        <text class="info-value">{{order.remark}}</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder" wx:if="{{order.status === 'pending'}}"></view>

    <!-- 底部操作栏：待支付 -->
    <view class="bottom-bar" wx:if="{{order.status === 'pending'}}">
      <button class="btn-cancel" bindtap="onCancel" loading="{{actionLoading}}">取消订单</button>
      <button class="btn-pay" bindtap="onPay" loading="{{actionLoading}}">去支付</button>
    </view>
  </block>
</view>
