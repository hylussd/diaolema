/* pages/shop/order-detail/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 订单状态区 */
.status-section {
  background: #3b82f6;
  color: #fff;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.status-tag-lg {
  font-size: 32rpx;
  font-weight: 700;
  padding: 8rpx 32rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.status-tag-lg.warning {
  background: rgba(255,255,255,0.25);
}

.status-tag-lg.info {
  background: rgba(255,255,255,0.2);
}

.status-tag-lg.success {
  background: rgba(255,255,255,0.2);
}

.status-tag-lg.muted {
  background: rgba(255,255,255,0.15);
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 区块 */
.section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

/* 收货地址 */
.address-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.addr-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.addr-phone {
  font-size: 28rpx;
  color: #6b7280;
}

.addr-detail {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* 商品明细 */
.order-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  display: flex;
  gap: 16rpx;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-specs {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 12rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

.item-qty {
  font-size: 26rpx;
  color: #6b7280;
}

/* 订单信息 */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #6b7280;
}

.info-value {
  font-size: 26rpx;
  color: #1f2937;
}

/* 底部占位 */
.bottom-placeholder {
  height: 160rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  z-index: 100;
}

.btn-cancel,
.btn-pay {
  height: 80rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
}

.btn-cancel {
  background: #fff;
  color: #6b7280;
  border: 2rpx solid #d1d5db;
}

.btn-pay {
  background: #3b82f6;
  color: #fff;
}
