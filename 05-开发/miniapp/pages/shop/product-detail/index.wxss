/* pages/shop/product-detail/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 轮播 */
.swiper {
  width: 100%;
  height: 700rpx;
  background: #f9fafb;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.product-info {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.price {
  font-size: 48rpx;
  font-weight: 700;
  color: #ef4444;
}

.sales {
  font-size: 24rpx;
  color: #9ca3af;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.5;
}

/* 规格 */
.section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.specs-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.spec-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.spec-name {
  font-size: 26rpx;
  color: #6b7280;
  width: 100rpx;
  flex-shrink: 0;
  padding-top: 6rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.spec-option {
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.spec-option.active {
  background: #fef3c7;
  color: #d97706;
  border-color: #f59e0b;
  font-weight: 600;
}

/* 商品详情描述 */
.description {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 底部占位 */
.bottom-placeholder {
  height: 160rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.bottom-bar-inner {
  display: flex;
  gap: 16rpx;
}

.btn-cart,
.btn-buy {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
}

.btn-cart {
  background: #fff;
  color: #3b82f6;
  border: 2rpx solid #3b82f6;
}

.btn-buy {
  background: #3b82f6;
  color: #fff;
}
