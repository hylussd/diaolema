/* pages/shop/products/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.search-wrap {
  background: #fff;
  padding: 16rpx 20rpx;
}

.search-input {
  height: 72rpx;
  background: #f3f4f6;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1f2937;
}

/* 分类横滑 */
.cat-scroll {
  background: #fff;
  padding: 16rpx 20rpx;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.cat-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  margin-right: 16rpx;
  transition: all 0.15s;
}

.cat-chip.active {
  background: #3b82f6;
  color: #fff;
  font-weight: 600;
}

/* 商品列表（2列网格） */
.product-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 20rpx;
}

.product-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.product-img {
  width: 100%;
  height: 320rpx;
  background: #f9fafb;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-sales {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.no-more {
  text-align: center;
  padding: 24rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #d1d5db;
}
