<!-- pages/shop/products/index.wxml -->
<view class="page">
  <!-- 搜索框 -->
  <view class="search-wrap">
    <input
      class="search-input"
      placeholder="搜索商品"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <!-- 分类横滑 -->
  <scroll-view class="cat-scroll" scroll-x>
    <view
      class="cat-chip {{selectedCategoryId === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="onCategoryTap"
      data-id="{{item.id}}"
    >{{item.icon}} {{item.name}}</view>
  </scroll-view>

  <!-- 商品列表 -->
  <view class="product-list" wx:if="{{products.length > 0}}">
    <view
      class="product-card"
      wx:for="{{products}}"
      wx:key="id"
      bindtap="onProductTap"
      data-id="{{item.id}}"
    >
      <image class="product-img" src="{{item.images && item.images[0] || '/assets/icons/me.png'}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-bottom">
          <text class="product-price">¥{{formatPrice(item.price)}}</text>
          <text class="product-sales">已售{{item.sales_count || 0}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:elif="{{!loading}}">
    <text class="empty-text">暂无商品</text>
  </view>

  <!-- 加载更多提示 -->
  <view class="load-more" wx:if="{{loading && products.length > 0}}">
    <text class="load-more-text">加载中...</text>
  </view>

  <!-- 没有更多 -->
  <view class="no-more" wx:if="{{!hasMore && products.length > 0}}">
    <text class="no-more-text">— 没有更多了 —</text>
  </view>
</view>
