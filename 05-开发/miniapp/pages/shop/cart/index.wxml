<!-- pages/shop/cart/index.wxml -->
<view class="page">
  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空购物车 -->
  <view class="empty-wrap" wx:elif="{{items.length === 0}}">
    <image class="empty-icon" src="/assets/icons/me.png" mode="aspectFit" />
    <text class="empty-text">购物车是空的</text>
    <button class="btn-go" bindtap="onGoShopping">去逛逛</button>
  </view>

  <block wx:else>
    <!-- 收货地址栏 -->
    <view class="address-bar">
      <text class="address-label">收货地址</text>
      <text class="address-text">浙江省杭州市西湖区（模拟地址）</text>
    </view>

    <!-- 全选 -->
    <view class="select-all-row">
      <view class="check-wrap" bindtap="onSelectAll">
        <view class="check {{selectedIds.length === items.length ? 'checked' : ''}}"></view>
        <text class="check-label">全选</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="cart-list">
      <view class="cart-item" wx:for="{{items}}" wx:key="id">
        <view class="check-wrap" bindtap="onCheckTap" data-id="{{item.id}}">
          <view class="check {{selectedIds.indexOf(item.id) !== -1 ? 'checked' : ''}}"></view>
        </view>
        <image class="item-img" src="{{item.images && item.images[0] || '/assets/icons/me.png'}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-specs">{{item.specs ? JSON.stringify(item.specs) : ''}}</text>
          <view class="item-bottom">
            <text class="item-price">¥{{formatPrice(item.price)}}</text>
            <view class="stepper">
              <view class="step-btn" bindtap="onDecrement" data-id="{{item.id}}">-</view>
              <text class="step-num">{{item.quantity}}</text>
              <view class="step-btn" bindtap="onIncrement" data-id="{{item.id}}">+</view>
            </view>
          </view>
        </view>
        <view class="delete-btn" bindtap="onDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>

    <!-- 底部固定栏 -->
    <view class="bottom-bar">
      <view class="bottom-info">
        <text class="total-label">合计</text>
        <text class="total-price">¥{{formatPrice(totalAmount)}}</text>
      </view>
      <button class="btn-checkout" bindtap="onCheckout" disabled="{{selectedIds.length === 0}}">
        结算{{selectedIds.length > 0 ? '(' + selectedIds.length + ')' : ''}}
      </button>
    </view>
  </block>
</view>
