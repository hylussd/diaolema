/* pages/shop/cart/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading-wrap,
.empty-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.4;
}

.btn-go {
  margin-top: 8rpx;
  background: #3b82f6;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

/* 收货地址 */
.address-bar {
  background: #fff;
  padding: 20rpx 24rpx;
  margin-bottom: 2rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.address-label {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
}

.address-text {
  font-size: 26rpx;
  color: #4b5563;
}

/* 全选 */
.select-all-row {
  background: #fff;
  padding: 16rpx 24rpx;
  margin-bottom: 2rpx;
}

.check-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d1d5db;
  transition: all 0.15s;
}

.check.checked {
  background: #3b82f6;
  border-color: #3b82f6;
}

.check-label {
  font-size: 26rpx;
  color: #4b5563;
}

/* 商品列表 */
.cart-list {
  padding: 0 20rpx;
}

.cart-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.item-specs {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 12rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #ef4444;
}

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 0;
}

.step-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-num {
  font-size: 28rpx;
  color: #1f2937;
  min-width: 60rpx;
  text-align: center;
}

.delete-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 8rpx;
  flex-shrink: 0;
}

/* 底部占位 */
.bottom-placeholder {
  height: 160rpx;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.bottom-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: #6b7280;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ef4444;
}

.btn-checkout {
  height: 80rpx;
  padding: 0 48rpx;
  background: #3b82f6;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
}

.btn-checkout[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}
