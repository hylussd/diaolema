/* pages/shop/orders/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Tab 栏 */
.tab-bar {
  background: #fff;
  white-space: nowrap;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #6b7280;
  position: relative;
}

.tab-item.active {
  color: #3b82f6;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #3b82f6;
  border-radius: 2rpx;
}

/* 订单卡片 */
.order-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.order-no {
  font-size: 24rpx;
  color: #6b7280;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.status-tag.warning {
  background: #fef3c7;
  color: #d97706;
}

.status-tag.info {
  background: #dbeafe;
  color: #1d4ed8;
}

.status-tag.success {
  background: #d1fae5;
  color: #059669;
}

.status-tag.muted {
  background: #f3f4f6;
  color: #9ca3af;
}

.order-time {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
}

/* 商品缩略图 */
.thumb-list {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.thumb-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #f9fafb;
}

.thumb-more {
  font-size: 24rpx;
  color: #9ca3af;
  padding-left: 4rpx;
}

.order-footer {
  display: flex;
  justify-content: flex-end;
}

.order-total {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.no-more {
  text-align: center;
  padding: 24rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #d1d5db;
}
