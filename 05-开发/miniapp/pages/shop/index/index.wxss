/* pages/shop/index/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

/* 分类横滑 */
.cat-scroll {
  white-space: nowrap;
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 32rpx;
  width: 100rpx;
}

.cat-icon {
  font-size: 56rpx;
  background: #fff;
  border-radius: 20rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 22rpx;
  color: #4b5563;
  text-align: center;
}

/* 商品网格（2列） */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.product-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.product-img {
  width: 100%;
  height: 320rpx;
  background: #f9fafb;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #ef4444;
}

.product-tag {
  font-size: 20rpx;
  background: #fef3c7;
  color: #d97706;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 新品横向滚动 */
.new-scroll {
  white-space: nowrap;
}

.new-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 220rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.new-img {
  width: 220rpx;
  height: 220rpx;
  background: #f9fafb;
}

.new-name {
  font-size: 24rpx;
  color: #1f2937;
  padding: 12rpx 12rpx 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.new-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #ef4444;
  padding: 4rpx 12rpx 16rpx;
}

/* 购物车悬浮按钮 */
.cart-fab {
  position: fixed;
  right: 24rpx;
  bottom: 200rpx;
  background: #3b82f6;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.4);
  z-index: 100;
}

.cart-fab-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.cart-fab-text {
  font-size: 20rpx;
}
