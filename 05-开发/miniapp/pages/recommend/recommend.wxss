.page {
  min-height: 100vh;
  background: #f0f4f8;
}

.map-preview {
  width: 100%;
  position: relative;
}

.map-overlay {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 10;
}

.loc-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(8px);
  padding: 12rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #374151;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.filter-card {
  background: #fff;
  margin: -40rpx 20rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  position: relative;
  z-index: 20;
}

.filter-row {
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.fish-scroll {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.fish-chip {
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  transition: all 0.15s;
}

.fish-chip.active {
  background: #dbeafe;
  color: #1d4ed8;
  font-weight: 600;
}

.two-col {
  display: flex;
  gap: 16rpx;
}

.two-col .filter-item {
  flex: 1;
}

.picker-val {
  padding: 16rpx 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
}

.btn-recommend {
  width: 100%;
  height: 88rpx;
  background: #3b82f6;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  border: none;
}

.advice-card {
  margin: 20rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 8rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #78350f;
  line-height: 1.6;
}

.result-list {
  padding: 0 20rpx 40rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.score-badge {
  width: 80rpx;
  height: 80rpx;
  background: #3b82f6;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.score-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

.result-body {
  flex: 1;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.result-dist {
  font-size: 24rpx;
  color: #6b7280;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag-fish {
  background: #f0fdf4;
  color: #16a34a;
}

.reason-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.reason-tag {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}

.result-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  font-size: 24rpx;
  color: #3b82f6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #9ca3af;
}
