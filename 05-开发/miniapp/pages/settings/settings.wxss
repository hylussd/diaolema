.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.section {
  background: #fff;
  margin-top: 16rpx;
}

.section-title {
  padding: 20rpx 24rpx 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1px solid #f3f4f6;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  overflow: hidden;
}

.item-label {
  font-size: 28rpx;
  color: #1f2937;
}

.item-value {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 32rpx;
  color: #d1d5db;
  flex-shrink: 0;
}

.footer {
  padding: 60rpx 24rpx;
}

.text-danger {
  color: #ef4444;
}
