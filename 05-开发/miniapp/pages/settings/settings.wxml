<!-- 设置页 -->
<view class="page">
  <view class="section">
    <view class="section-title">服务设置</view>
    <view class="setting-item" bindtap="changeApiBase">
      <view class="item-left">
        <text class="item-label">服务端地址</text>
        <text class="item-value text-secondary text-sm">{{apiBase}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">账号信息</view>
    <view class="setting-item">
      <view class="item-left">
        <text class="item-label">OpenID</text>
        <text class="item-value text-secondary text-sm" selectable>{{openid}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">其他</view>
    <view class="setting-item" bindtap="showAbout">
      <text class="item-label">关于小程序</text>
      <text class="arrow">›</text>
    </view>
    <view class="setting-item" bindtap="showPrivacy">
      <text class="item-label">隐私说明</text>
      <text class="arrow">›</text>
    </view>
    <view class="setting-item" bindtap="clearCache">
      <text class="item-label text-danger">清空本地缓存</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="footer">
    <text class="text-secondary text-sm text-center">钓了吗 v1.0.0 P0 MVP</text>
  </view>
</view>
